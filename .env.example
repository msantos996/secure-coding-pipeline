# ============================================================
#  Configuracao do Provider LLM
#  Copia este ficheiro para .env e preenche os valores.
#  O ficheiro .env NUNCA deve ser commitado no git.
# ============================================================

# Provider a usar: claude | openai | ollama
LLM_PROVIDER=claude

# Modelo especifico (opcional — usa o default do provider se omitido)
# Claude:  claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-7
# OpenAI:  gpt-4o | gpt-4o-mini | gpt-4-turbo
# Ollama:  llama3 | mistral | phi3 | gemma2
LLM_MODEL=claude-sonnet-4-6

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Opcional: endpoint alternativo OpenAI-compatible (ex: Azure, Groq, LM Studio)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── Ollama (local, gratuito) ──────────────────────────────────
# Instalar: https://ollama.com/download
# Arrancar: ollama serve
# Modelos:  ollama pull llama3
OLLAMA_HOST=http://localhost:11434
