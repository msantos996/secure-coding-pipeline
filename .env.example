# ============================================================
#  CONFIGURACAO DO PIPELINE
#  1. Copia este ficheiro: cp .env.example .env  (ou copia manualmente)
#  2. Escolhe o provider LLM e preenche a API key correspondente
#  3. O ficheiro .env nunca e enviado para o git (esta protegido)
# ============================================================

# --- PASSO 1: Escolhe o provider ---
# Opcoes: claude | openai | ollama
# Ollama e gratuito e corre localmente (ver instrucoes abaixo)
LLM_PROVIDER=claude

# --- PASSO 2: Escolhe o modelo (opcional) ---
# claude  -> claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-7
# openai  -> gpt-4o | gpt-4o-mini
# ollama  -> llama3 | mistral | phi3 | gemma2
LLM_MODEL=claude-sonnet-4-6

# --- PASSO 3: Preenche a API key do provider escolhido ---

# Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Ollama - gratuito, sem API key necessaria
# Instalar : https://ollama.com/download
# Arrancar : ollama serve
# Modelo   : ollama pull llama3
OLLAMA_HOST=http://localhost:11434
